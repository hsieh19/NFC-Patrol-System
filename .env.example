# =================================================================
# 飞书开放平台配置 (Feishu/Lark Configuration)
# =================================================================

LARK_APP_ID=cli_xxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_LARK_APP_ID=cli_xxxxxxxxxxxx

# =================================================================
# 数据库切换 (Database Selection - 运行时生效)
# =================================================================

# 切换开关: sqlite 或 mysql
# - 当=sqlite时，运行时将锁定使用 file:./dev.db (即 prisma/dev.db)。
# - 当=mysql时，运行时将无视 DATABASE_URL，改用下方详细参数拼接的连接串。
DB_TYPE=sqlite

# =================================================================
# MySQL 详细参数 (仅在 DB_TYPE=mysql 时生效)
# =================================================================

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=nfc_patrol_system

# =================================================================
# 系统运行环境配置
# =================================================================

NODE_ENV=development

# =================================================================
# 安全与加密配置 (Security & Encryption Configuration)
# =================================================================

# 初始新建用户的默认密码
DEFAULT_PASSWORD=123456

# JWT 签发密钥 (生产环境请务必替换为32位以上复杂长字符)
JWT_SECRET="nfc-patrol-system-super-secret-key-change-in-prod"
