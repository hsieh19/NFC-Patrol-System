# =================================================================
# 数据库配置 (Database Configuration)
# =================================================================

# 切换开关: sqlite 或 mysql
# - 当=sqlite时，运行时将锁定使用 file:./dev.db (即根目录下的 dev.db 或 prisma/dev.db)。
# - 当=mysql时，运行时将根据下方详细参数拼接连接串。
DB_TYPE=sqlite

# MySQL 详细参数 (仅在 DB_TYPE=mysql 时生效)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=nfc_patrol_system

# =================================================================
# 安全与加密配置 (Security & Encryption Configuration)
# =================================================================

# 后续手动创建普通用户/巡更员时的“默认初始密码” (在后台管理系统中点击“新增人员”且未手动设定密码时使用)
# 注意：超级管理员密码是在首次访问系统时在 /init 页面手动交互设置的，不在此处配置。
DEFAULT_PASSWORD=admin123456

# JWT 签发密钥 (生产环境请务必替换为32位以上随机字符串)
JWT_SECRET="replace-with-a-very-long-and-secure-random-string-in-production"

# =================================================================
# 运行环境配置 (Environment)
# =================================================================

NODE_ENV=development
PORT=3000
