generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  code        String       @id
  name        String
  permissions String       @default("[]")
  description String?
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  checkpoints Checkpoint[]
  plans       Plan[]
  routes      Route[]
  users       User[]
}

model User {
  id         String         @id @default(cuid())
  username   String?        @unique
  password   String?
  name       String
  avatar     String?
  department String?
  roleCode   String         @default("OPERATOR")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  groupId    String?
  patrols    PatrolRecord[]
  repairs    RepairReport[]
  group      UserGroup?     @relation(fields: [groupId], references: [id])
  role       Role           @relation(fields: [roleCode], references: [code], onDelete: SetDefault)
}

model UserGroup {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  checkpoints Checkpoint[]
  plans       Plan[]
  routes      Route[]
  users       User[]
}

model SystemConfig {
  id            Int      @id @default(autoincrement())
  isInitialised Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

model Checkpoint {
  id         String            @id @default(cuid())
  nfcTagId   String            @unique
  name       String
  location   String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  groupId    String
  roleCode   String
  role       Role              @relation(fields: [roleCode], references: [code], onDelete: Cascade)
  group      UserGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  records    PatrolRecord[]
  repairs    RepairReport[]
  routeLinks RouteCheckpoint[]
}

model Route {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  groupId     String
  roleCode    String
  plans       Plan[]
  role        Role              @relation(fields: [roleCode], references: [code], onDelete: Cascade)
  group       UserGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  checkpoints RouteCheckpoint[]
}

model RouteCheckpoint {
  id           String     @id @default(cuid())
  routeId      String
  checkpointId String
  order        Int        @default(0)
  checkpoint   Checkpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)
  route        Route      @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([routeId, checkpointId])
}

model Plan {
  id         String    @id @default(cuid())
  name       String
  routeId    String
  startTime  String
  endTime    String
  assignedTo String?
  frequency  String    @default("DAILY")
  planType   String    @default("ORDERED")
  groupId    String
  roleCode   String
  isArchived Boolean   @default(false)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  role       Role      @relation(fields: [roleCode], references: [code], onDelete: Cascade)
  group      UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  route      Route     @relation(fields: [routeId], references: [id])
}

model PatrolRecord {
  id                 String      @id @default(cuid())
  checkpointId       String?
  checkpointName     String?
  checkpointLocation String?
  userId             String
  status             String      @default("NORMAL")
  notes              String?
  offlineId          String?     @unique
  createdAt          DateTime    @default(now())
  user               User        @relation(fields: [userId], references: [id])
  checkpoint         Checkpoint? @relation(fields: [checkpointId], references: [id])
}

model RepairReport {
  id           String      @id @default(cuid())
  checkpointId String?
  userId       String
  description  String
  imageUrls    String?
  status       String      @default("PENDING")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id])
  checkpoint   Checkpoint? @relation(fields: [checkpointId], references: [id])
}
